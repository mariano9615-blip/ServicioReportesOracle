<UserControl x:Class="ServicioReportesOracle.UI.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Task List Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Listado de Tareas" Margin="15,15,15,10" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}"
                         Background="Transparent" BorderThickness="0" Margin="5"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#252525"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" CornerRadius="8" Margin="0,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding Nombre}" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="{Binding Archivo}" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" Content="+ AGREGAR NUEVA TAREA" Command="{Binding AddTaskCommand}" 
                        Margin="15" Padding="10" Background="#2a2a2a" Foreground="White">
                     <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Task Editor -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" DataContext="{Binding SelectedTask}" 
                          Visibility="{Binding DataContext.SelectedTask, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Editando Tarea" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryLightBrush}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Nombre de la Tarea" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Archivo SQL" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Archivo, UpdateSourceTrigger=PropertyChanged}" Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Frecuencia (minutos)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FrecuenciaMinutos}" Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{StaticResource OutlineBrush}" Margin="0,10,0,20"/>

                    <!-- Checkboxes Section -->
                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <CheckBox Content="Habilitar Envío de Correo" IsChecked="{Binding EnviarCorreo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <CheckBox Content="Habilitar Tracking" IsChecked="{Binding Track, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    </UniformGrid>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Campo de Tracking" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CampoTrack}" Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Destinatarios (uno por línea o separados por coma)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Destinatarios, Converter={StaticResource StringListConverter}}" 
                                 AcceptsReturn="True" Height="80" 
                                 Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Campos a excluir del reporte" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ExcluirCampos, Converter={StaticResource StringListConverter}}" 
                                 Background="#2a2a2a" Foreground="White" Padding="8" BorderThickness="0"/>
                    </StackPanel>

                    <!-- Mail Templates Tabs -->
                    <TextBlock Text="Configuración de Plantillas" Foreground="White" FontWeight="Bold" Margin="0,10,0,10"/>
                    <TabControl>
                        <TabItem Header="📧 Plantilla CON ERROR">
                            <Border Background="#252525" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Asunto" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Mail.AsuntoConError, UpdateSourceTrigger=PropertyChanged}" Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" Margin="0,0,0,15"/>
                                    
                                    <TextBlock Text="Cuerpo" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Mail.CuerpoConError, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="150" Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" TextWrapping="Wrap"/>
                                    
                                    <TextBlock Text="Campos a incluir (Errores)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="10,15,0,5"/>
                                    <TextBox Text="{Binding CamposCorreo.Errores, Converter={StaticResource StringListConverter}}" 
                                             Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅" FontFamily="Segoe UI Emoji" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="SIN ERROR" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Border Background="#252525" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Asunto" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Mail.AsuntoSinError, UpdateSourceTrigger=PropertyChanged}" Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" Margin="0,0,0,15"/>
                                    
                                    <TextBlock Text="Cuerpo" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Mail.CuerpoSinError, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="150" Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" TextWrapping="Wrap"/>

                                    <TextBlock Text="Campos a incluir (Resueltos)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="10,15,0,5"/>
                                    <TextBox Text="{Binding CamposCorreo.Resueltos, Converter={StaticResource StringListConverter}}" 
                                             Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <!-- Panel de confirmación de eliminación -->
                    <Border Margin="0,20,0,0" CornerRadius="8" Padding="14,12"
                            Background="#22FF4B4B" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                            Visibility="{Binding DataContext.PendingDeleteTask, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,10">
                                <Run Text="¿Eliminás la tarea '"/>
                                <Run Text="{Binding DataContext.PendingDeleteTask.Nombre, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                                <Run Text="'? Esta acción no se puede deshacer."/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sí, eliminar"
                                        Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="{StaticResource ErrorBrush}" Foreground="White"
                                        FontWeight="Bold" Padding="14,8" Margin="0,0,10,0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                </Button>
                                <Button Content="Cancelar"
                                        Command="{Binding DataContext.CancelDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="{StaticResource SurfaceContainerHighBrush}" Foreground="{StaticResource OnSurfaceBrush}"
                                        FontWeight="Bold" Padding="14,8">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="📧 TEST CORREO"
                                Command="{Binding DataContext.TestEmailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                IsEnabled="{Binding DataContext.IsNotBusy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Background="#1F5C2E" Foreground="White" Padding="18,12" FontWeight="Bold" Margin="0,0,10,0"
                                ToolTip="Envía un correo de prueba usando la plantilla CON ERROR de esta tarea">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1B6B35"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Opacity="{TemplateBinding Opacity}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#27923F"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#145228"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Padding="25,12" FontWeight="Bold" Margin="0,0,10,0">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="GUARDAR CAMBIOS" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" Background="{StaticResource ErrorBrush}" Foreground="White"
                                Opacity="0.6" Padding="15,12">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ELIMINAR" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
