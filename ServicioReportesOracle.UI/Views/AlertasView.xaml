<UserControl x:Class="ServicioReportesOracle.UI.Views.AlertasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Foreground="{StaticResource OnSurfaceBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="💌 Alertas SMTP Enviadas"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}"/>
                <TextBlock Text="{Binding TotalAlertas, StringFormat=' ({0} total)'}"
                           FontSize="16" Margin="8,0,0,0"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           VerticalAlignment="Bottom"/>
                <TextBlock Text="{Binding AlertasHoy, StringFormat=' | {0} hoy'}"
                           FontSize="14" Margin="4,0,0,0"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <Button Grid.Column="1" Content="📊 Exportar a Excel"
                    Command="{Binding ExportarCommand}"
                    Background="{StaticResource SurfaceContainerHighBrush}"
                    Foreground="{StaticResource OnSurfaceBrush}"
                    BorderBrush="{StaticResource OutlineBrush}"
                    BorderThickness="1"
                    Style="{x:Null}"
                    Margin="0,0,8,0" Padding="12,8"/>

            <Button Grid.Column="2" Content="🔄 Actualizar"
                    Command="{Binding ActualizarCommand}"
                    Background="{StaticResource SurfaceContainerHighBrush}"
                    Foreground="{StaticResource OnSurfaceBrush}"
                    BorderBrush="{StaticResource OutlineBrush}"
                    BorderThickness="1"
                    Style="{x:Null}"
                    Padding="12,8"/>
        </Grid>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Alertas}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="True"
                  SelectionMode="Extended"
                  ClipboardCopyMode="IncludeHeader"
                  Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource OutlineBrush}"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource OutlineBrush}"
                  RowBackground="{StaticResource SurfaceBrush}"
                  AlternatingRowBackground="#1A1A1A"
                  Foreground="{StaticResource OnSurfaceBrush}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding TimestampFormateado}" Width="120"/>

                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoAmigable}" Width="220"/>

                <DataGridTextColumn Header="Asunto" Binding="{Binding Asunto}" Width="400">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding Asunto}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Detalle" Binding="{Binding Detalle}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding Detalle}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="ID Ref." Binding="{Binding IdReferencia}" Width="140"/>

                <DataGridTextColumn Header="Destinatarios" Binding="{Binding DestinatariosStr}" Width="250">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding DestinatariosStr}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
