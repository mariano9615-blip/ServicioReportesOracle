<UserControl x:Class="ServicioReportesOracle.UI.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="40,30"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="440" MaxWidth="520">
            <StackPanel>
                <!-- Título -->
                <TextBlock Text="🔑 Cambiar Contraseña" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryLightBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="Actualizá la contraseña de acceso a esta consola."
                           FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,28"/>

                <Border Height="1" Background="{StaticResource OutlineBrush}" Margin="0,0,0,28"/>

                <!-- Contraseña actual -->
                <TextBlock Text="Contraseña actual" Foreground="{StaticResource OnSurfaceVariantBrush}"
                           FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="CurrentPasswordBox"
                             Height="40" Margin="0,0,0,6"
                             Background="#2a2a2a" Foreground="White" CaretBrush="White"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="12,0" FontSize="14"
                             PasswordChanged="CurrentPasswordBox_Changed">
                    <PasswordBox.Resources>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <TextBlock Text="Contraseña actual incorrecta."
                           Foreground="{StaticResource ErrorBrush}" FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,16"
                           Visibility="{Binding ShowCurrentWrongError, Converter={StaticResource BoolToVis}}"/>

                <!-- Nueva contraseña -->
                <TextBlock Text="Nueva contraseña" Foreground="{StaticResource OnSurfaceVariantBrush}"
                           FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="NewPasswordBox"
                             Height="40" Margin="0,0,0,16"
                             Background="#2a2a2a" Foreground="White" CaretBrush="White"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="12,0" FontSize="14"
                             PasswordChanged="NewPasswordBox_Changed">
                    <PasswordBox.Resources>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Repetir nueva contraseña -->
                <TextBlock Text="Repetir nueva contraseña" Foreground="{StaticResource OnSurfaceVariantBrush}"
                           FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Height="40" Margin="0,0,0,6"
                             Background="#2a2a2a" Foreground="White" CaretBrush="White"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="12,0" FontSize="14"
                             PasswordChanged="ConfirmPasswordBox_Changed">
                    <PasswordBox.Resources>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Error contraseñas no coinciden -->
                <TextBlock Text="Las contraseñas nuevas no coinciden."
                           Foreground="{StaticResource ErrorBrush}" FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,0"
                           Visibility="{Binding ShowMismatchError, Converter={StaticResource BoolToVis}}"/>

                <Border Height="1" Background="{StaticResource OutlineBrush}" Margin="0,24,0,24"/>

                <!-- Botones -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕ CANCELAR"
                            Command="{Binding CancelCommand}"
                            Background="#2a2a2a" Foreground="{StaticResource OnSurfaceBrush}"
                            Padding="20,12" FontWeight="Bold" Margin="0,0,10,0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                    <Button Command="{Binding SaveCommand}"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            Padding="25,12" FontWeight="Bold">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="GUARDAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
