<UserControl x:Class="ServicioReportesOracle.UI.Views.MetricasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="900"
             Foreground="{StaticResource OnSurfaceBrush}">

    <UserControl.Resources>
        <!-- Estilo de cada barra vertical -->
        <Style x:Key="BarItemStyle" TargetType="Border">
            <Setter Property="Background"        Value="{Binding Fill}"/>
            <Setter Property="CornerRadius"      Value="2,2,0,0"/>
            <Setter Property="Margin"            Value="1.5,0"/>
            <Setter Property="Height"            Value="{Binding BarHeightPx}"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="ToolTip"           Value="{Binding Tooltip}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Título + botón Actualizar ── -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Métricas (48 horas)"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource OnSurfaceBrush}"/>

            <Button Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceContainerHighBrush}"
                    Foreground="{StaticResource OnSurfaceBrush}"
                    BorderBrush="{StaticResource OutlineBrush}"
                    BorderThickness="1"
                    Padding="15,8"
                    Style="{x:Null}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄"
                               FontFamily="Segoe UI Emoji"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Actualizar"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Fila 1: gráficos de barras ── -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- IDs procesados por corrida -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="16"
                    MinHeight="190"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="IDs procesados por corrida (últimas 20)"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Gráfico de barras IDs -->
                    <Grid Grid.Row="1" MinHeight="90">
                        <!-- Área de barras (solo cuando hay datos) -->
                        <Border Background="{StaticResource SurfaceContainerHighBrush}"
                                CornerRadius="4"
                                Padding="4,4,4,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TieneDatosCore}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ItemsControl ItemsSource="{Binding IdsBarItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Contenedor que establece la altura total disponible -->
                                        <Grid>
                                            <Border Style="{StaticResource BarItemStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Placeholder "Sin datos aun" -->
                        <TextBlock Text="Sin datos aun"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   Opacity="0.4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TieneDatosCore}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Label Min/Max IDs -->
                    <TextBlock Text="{Binding IdsBarLabel}"
                               Grid.Row="2"
                               FontSize="12"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TieneDatosCore}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Duración por corrida -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="16"
                    MinHeight="190"
                    Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Duración por corrida en segundos (últimas 20)"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Gráfico de barras Duración -->
                    <Grid Grid.Row="1" MinHeight="90">
                        <Border Background="{StaticResource SurfaceContainerHighBrush}"
                                CornerRadius="4"
                                Padding="4,4,4,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TieneDatosUI}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ItemsControl ItemsSource="{Binding DuracionBarItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border Style="{StaticResource BarItemStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Placeholder "Sin datos aun" -->
                        <TextBlock Text="Sin datos aun"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   Opacity="0.4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TieneDatosUI}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Label Min/Max Duración -->
                    <TextBlock Text="{Binding DuracionBarLabel}"
                               Grid.Row="2"
                               FontSize="12"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TieneDatosUI}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Fila 2: KPIs numéricos ── -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Corridas hoy vs ayer"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                    <TextBlock Text="{Binding CorridasHoyVsAyer}"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Alertas enviadas hoy"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                    <TextBlock Text="{Binding AlertasHoy}"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="{Binding ColorAlertas}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Fila 3: Distribución FULL/DELTA ── -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Distribución FULL vs DELTA (hoy)"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,10"/>

                <Grid Grid.Row="1" Margin="0,0,0,6" Width="260">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="FULL"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}"
                               HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1"
                               Text="DELTA"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <Border Grid.Row="2"
                        Height="12"
                        Width="260"
                        CornerRadius="6"
                        Background="{StaticResource SurfaceContainerHighBrush}">
                    <Canvas Width="260"
                            Height="12"
                            HorizontalAlignment="Stretch"
                            ClipToBounds="True">
                        <Border Width="{Binding FullBarWidth}"
                                Height="12"
                                Background="{StaticResource PrimaryBrush}"
                                Canvas.Left="0"
                                Canvas.Top="0"/>
                        <Border Width="{Binding DeltaBarWidth}"
                                Height="12"
                                Background="{StaticResource WarningBrush}"
                                Canvas.Left="{Binding FullBarWidth}"
                                Canvas.Top="0"/>
                    </Canvas>
                </Border>

                <Grid Grid.Row="3" Margin="0,6,0,0" Width="260">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Foreground="{StaticResource OnSurfaceVariantBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} corridas - {1}%">
                                <Binding Path="FullHoy"/>
                                <Binding Path="FullPorcentaje"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Right">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} corridas - {1}%">
                                <Binding Path="DeltaHoy"/>
                                <Binding Path="DeltaPorcentaje"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
