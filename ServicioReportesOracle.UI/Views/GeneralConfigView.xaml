<UserControl x:Class="ServicioReportesOracle.UI.Views.GeneralConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Configuración General" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryLightBrush}" Margin="0,0,0,20"/>

            <!-- Oracle Section -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Base de Datos Oracle" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,15"/>
                    <TextBlock Text="Cadena de Conexión" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <!-- Cadena de conexión + botón Probar Oracle -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Config.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BackgroundBrush}" Foreground="White"
                                 BorderThickness="0" Padding="8"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Command="{Binding TestOracleCommand}"
                                ToolTip="Probar conexión Oracle"
                                Padding="14,8"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔌" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Probar Conexión Oracle" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding OracleStatus}" Foreground="{StaticResource PrimaryLightBrush}" FontStyle="Italic" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Ruta Excel (Reportes)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Config.RutaExcel, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{StaticResource BackgroundBrush}" Foreground="White"
                                         BorderThickness="0" Padding="8" Margin="0,0,4,0"/>
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseExcelFolderCommand}"
                                        ToolTip="Seleccionar carpeta"
                                        Width="32" Height="22" VerticalAlignment="Center" Margin="5,0,0,0"
                                        Padding="0" FontWeight="Bold"
                                        Background="{StaticResource SurfaceContainerHighBrush}"
                                        Foreground="{StaticResource OnSurfaceBrush}">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                    </Button.Resources>
                                    <TextBlock Text="[...]" FontFamily="Consolas" FontSize="11"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Ruta Scripts SQL" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Config.RutaSQL, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{StaticResource BackgroundBrush}" Foreground="White"
                                         BorderThickness="0" Padding="8" Margin="0,0,4,0"/>
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseSqlFolderCommand}"
                                        ToolTip="Seleccionar carpeta"
                                        Width="32" Height="22" VerticalAlignment="Center" Margin="5,0,0,0"
                                        Padding="0" FontWeight="Bold"
                                        Background="{StaticResource SurfaceContainerHighBrush}"
                                        Foreground="{StaticResource OnSurfaceBrush}">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                    </Button.Resources>
                                    <TextBlock Text="[...]" FontFamily="Consolas" FontSize="11"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Empresa Section -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Identificación" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,15"/>
                    <TextBlock Text="Empresa / Cliente" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding Config.Empresa, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BackgroundBrush}" Foreground="White"
                             BorderThickness="0" Padding="8"
                             Tag="Ej: Posse, ACA, Carabelas..."/>
                    <TextBlock Text="Se antepone como [Empresa] en el asunto de los correos enviados."
                               Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="11"
                               Margin="0,4,0,0" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <!-- SMTP Section -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Configuración SMTP (Correo)" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Servidor SMTP" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding Config.ServidorSMTP}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Puerto" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding Config.PuertoSMTP}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Remitente" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,15,0,2"/>
                    <TextBox Text="{Binding Config.Remitente}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Usuario SMTP" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding Config.UsuarioSMTP}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Clave SMTP" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Contraseña enmascarada (estado por defecto) -->
                        <PasswordBox x:Name="SmtpPasswordBox" Grid.Column="0"
                                     Background="{StaticResource BackgroundBrush}" Foreground="White"
                                     CaretBrush="White" BorderThickness="0" Padding="8"
                                     PasswordChanged="SmtpPasswordBox_PasswordChanged">
                            <PasswordBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                            </PasswordBox.Resources>
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SmtpPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <!-- Contraseña en texto plano (solo visible con clave maestra) -->
                        <TextBox Grid.Column="0"
                                 Text="{Binding SmtpPasswordPlainText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource PrimaryLightBrush}"
                                 BorderThickness="0" Padding="8" FontFamily="Consolas">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SmtpPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Botón ojo (toggle: 👁 para revelar, 🙈 para ocultar) -->
                        <Button Grid.Column="1"
                                Command="{Binding ShowSmtpPasswordCommand}"
                                ToolTip="Ver / ocultar contraseña (requiere clave maestra)"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,0" Margin="4,0,0,0"
                                VerticalAlignment="Center" Cursor="Hand">
                            <!-- Icono 👁 cuando la clave está enmascarada -->
                            <TextBlock FontFamily="Segoe UI Emoji" FontSize="15" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="👁"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SmtpPasswordVisible}" Value="True">
                                                <Setter Property="Text" Value="🙈"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <!-- Indicador de encriptación -->
                        <Border Grid.Column="2" CornerRadius="4" Padding="6,3" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SmtpEncryptionIsEncrypted}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SmtpEncryptionLabel}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource BackgroundBrush}"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Mlogis Section -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Integración Mlogis (SOAP)" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,15"/>
                    <CheckBox IsChecked="{Binding Config.HabilitarMlogis}" Content="Habilitar Integración Mlogis" Foreground="White" Margin="0,0,0,15"/>

                    <TextBlock Text="Dominio / Usuario" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.Dominio}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="URL Autentificación" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.UrlAutentificacion}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="URL Web Service (WS)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.UrlWS}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Frecuencia SOAP (min)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding Config.FrecuenciaSoapMinutos, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Delay Comparación (min)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding Config.DelayComparacionMinutos, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Intervalo Reconciliación (h)" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding Config.IntervaloReconciliacionHoras, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Última Ejecución SOAP / Última Reconciliación (solo lectura) -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="10,8" Margin="0,15,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Última Ejecución SOAP:" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding UltimaEjecucionSoapDisplay}" Foreground="{StaticResource PrimaryLightBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Última Reconciliación Full:" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding UltimaReconciliacionDisplay}" Foreground="{StaticResource PrimaryLightBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Content="Probar Conexión SOAP" Command="{Binding TestSoapCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,15,0,0" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock Text="{Binding SoapStatus}" Foreground="{StaticResource PrimaryLightBrush}" FontStyle="Italic" Margin="0,10,0,0"/>

                    <Border Height="1" Background="{StaticResource OutlineBrush}" Margin="0,20,0,0"/>

                    <!-- Sección A: Estado actual del WebService -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,15,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Estado actual del WebService" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Command="{Binding RefreshWsStateCommand}"
                                        Padding="10,5" Background="{StaticResource SurfaceContainerHighBrush}"
                                        Foreground="{StaticResource OnSurfaceBrush}" FontSize="12">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔄" FontFamily="Segoe UI Emoji" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Actualizar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Indicador visual -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WsStatusEsOk}" Value="False">
                                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding WsStatusText}" Foreground="{StaticResource OnSurfaceBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Fechas -->
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Última vez caído: " Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding WsUltimaVezCaido}" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="Última vez recuperado: " Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding WsUltimaVezRecuperado}" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Sección B: Configuración de alertas del Health Check -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Configuración de Alertas Health Check" FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="Destinatarios (uno por línea o separados por coma)"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Config.HealthCheckSoap.Destinatarios,
                                             Converter={StaticResource StringListConverter},
                                             UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" IsReadOnly="False" Height="60"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#1a1a1a" Foreground="White" Padding="8"
                                     BorderThickness="0" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <TextBlock Text="Plantillas de alertas" FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                            <TabControl>
                                <TabItem>
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔴" FontFamily="Segoe UI Emoji" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="CAÍDO" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <Border Background="#252525" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Asunto" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.HealthCheckSoap.AsuntoCaido, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" Margin="0,0,0,12"/>
                                            <TextBlock Text="Cuerpo" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.HealthCheckSoap.CuerpoCaido, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="100"
                                                     Background="#1a1a1a" Foreground="White" Padding="8"
                                                     BorderThickness="0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                                <TabItem>
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✅" FontFamily="Segoe UI Emoji" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="RECUPERADO" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <Border Background="#252525" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Asunto" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.HealthCheckSoap.AsuntoRecuperado, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#1a1a1a" Foreground="White" Padding="8" BorderThickness="0" Margin="0,0,0,12"/>
                                            <TextBlock Text="Cuerpo" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.HealthCheckSoap.CuerpoRecuperado, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="100"
                                                     Background="#1a1a1a" Foreground="White" Padding="8"
                                                     BorderThickness="0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                            </TabControl>

                            <Button Command="{Binding SaveHealthCheckCommand}"
                                    HorizontalAlignment="Left" Padding="16,9" Margin="0,12,0,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Guardar Alertas Health Check" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- System & Messages Section -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Sistema y Mensajes" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,15"/>
                    <CheckBox IsChecked="{Binding Config.ModoDebug}" Content="Modo Debug" Foreground="White" Margin="0,0,0,15"/>

                    <TextBlock Text="Msj. Nuevos Movimientos" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.MensajeNuevosMovimientos}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Msj. Movimientos Resueltos" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.MensajeMovimientosResueltos}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Msj. Todo OK" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Config.MensajeTodoOK}" Background="{StaticResource BackgroundBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,5"/>
                </StackPanel>
            </Border>

            <!-- Panel de confirmación: backup fallido -->
            <Border Visibility="{Binding PendingBackupFail, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#1AFFC107" BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="No se pudo crear el backup del config. ¿Deseás continuar guardando?"
                               Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Continuar guardando" Command="{Binding ConfirmSaveCommand}"
                                Padding="14,8" Margin="0,0,10,0"
                                Background="{StaticResource WarningBrush}"
                                Foreground="{StaticResource BackgroundBrush}" FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="Cancelar" Command="{Binding CancelSaveCommand}"
                                Padding="14,8"
                                Background="{StaticResource SurfaceContainerHighBrush}"
                                Foreground="{StaticResource OnSurfaceBrush}" FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Command="{Binding SaveCommand}" Height="50" Margin="0,30,0,50" Background="{StaticResource PrimaryBrush}" Foreground="White" FontSize="16" FontWeight="Bold">
                 <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="GUARDAR CONFIGURACIÓN" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
