<UserControl x:Class="ServicioReportesOracle.UI.Views.ServiceControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ServiceButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Control del Servicio" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryLightBrush}" Margin="0,0,0,20"/>

            <!-- ADMIN WARNING CARD — visible solo si NO es admin -->
            <Border Background="#1AFF4B4B" CornerRadius="14" Padding="24,20" Margin="0,0,0,20"
                    BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                    Visibility="{Binding IsNotAdmin, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="!" FontSize="40" HorizontalAlignment="Center"
                               Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,10" FontWeight="Bold"/>
                    <TextBlock Text="La aplicación no está ejecutándose como Administrador"
                               FontSize="16" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="13"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                        Hacé clic derecho sobre el ejecutable → Ejecutar como administrador
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- STATUS CARD -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="40,30" Margin="0,0,0,20">
                <StackPanel>

                    <!-- Dot + status text -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Ellipse Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,14,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="{Binding StatusText}" FontSize="34" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Uptime -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                        <TextBlock Text="Uptime: " Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UptimeText}" Foreground="{StaticResource OnSurfaceBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource OutlineBrush}" Margin="0,0,0,28"/>

                    <!-- Iniciar / Detener — deshabilitados si no es admin -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="▶  Iniciar" Command="{Binding StartCommand}"
                                IsEnabled="{Binding CanStart}"
                                Style="{StaticResource ServiceButtonStyle}"
                                Background="{StaticResource SuccessBrush}"
                                Margin="0,0,16,0"/>
                        <Button Content="■  Detener" Command="{Binding StopCommand}"
                                IsEnabled="{Binding CanStop}"
                                Style="{StaticResource ServiceButtonStyle}"
                                Background="{StaticResource ErrorBrush}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- INSTALL / UNINSTALL CARD -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="30">
                <StackPanel>
                    <TextBlock Text="Administración del Servicio" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,16"/>

                    <!-- Info UAC -->
                    <Border Background="#1AFFC107" CornerRadius="8" Padding="14,10" Margin="0,0,0,24"
                            BorderBrush="#40FFC107" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!" FontSize="16" Foreground="{StaticResource WarningBrush}"
                                       Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="13" VerticalAlignment="Center">
                                <Run FontWeight="SemiBold">Requiere permisos de administrador.</Run>
                                <Run>Se solicitará elevación UAC al ejecutar.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding InstallCommand}"
                                IsEnabled="{Binding IsAdmin}"
                                Style="{StaticResource ServiceButtonStyle}"
                                Background="{StaticResource PrimaryBrush}"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Instalar servicio" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding UninstallCommand}"
                                IsEnabled="{Binding IsAdmin}"
                                Style="{StaticResource ServiceButtonStyle}"
                                Background="#8B2020">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Desinstalar servicio" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12"
                               Margin="0,16,0,0" Opacity="0.7">
                        Los scripts install.bat y uninstall.bat deben estar en la misma carpeta que el ejecutable.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
