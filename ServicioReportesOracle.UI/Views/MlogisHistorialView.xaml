<UserControl x:Class="ServicioReportesOracle.UI.Views.MlogisHistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Estilo para celdas de texto del DataGrid: Consolas, color suave -->
        <Style x:Key="DataCellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20" LastChildFill="False">
            <TextBlock Text="Registros SOAP" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryLightBrush}" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" VerticalAlignment="Center">

                <!-- Segmented toggle: Por Corrida | Por ID único -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="3" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ToggleModoCorridaCommand}" Padding="12,5">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModoCorrida}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Por Corrida" VerticalAlignment="Center"/>
                        </Button>

                        <Button Command="{Binding ToggleModoUnicoCommand}" Padding="12,5">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModoCorrida}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Por ID único" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Botón Exportar a Excel -->
                <Button Command="{Binding ExportToExcelCommand}" Margin="0,0,10,0" Padding="15,5"
                        Background="{StaticResource SurfaceBrush}" Foreground="White"
                        ToolTip="Exportar datos actuales a Excel">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Exportar a Excel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Botón Buscar (Ctrl+F) -->
                <Button Command="{Binding ToggleSearchCommand}" Margin="0,0,10,0" Padding="15,5"
                        Background="{StaticResource SurfaceBrush}" Foreground="White"
                        ToolTip="Buscar (Ctrl+F)">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Buscar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Botón Actualizar -->
                <Button Command="{Binding RefreshCommand}" Padding="15,5"
                        Background="{StaticResource SurfaceBrush}" Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Actualizar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- ── Contenido principal ────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Barra de búsqueda (Ctrl+F) -->
                <Border Grid.Row="0"
                        Visibility="{Binding SearchVisibility}"
                        Background="{StaticResource SurfaceContainerHighBrush}"
                        CornerRadius="8" Margin="0,0,0,8" Padding="10,7">
                    <DockPanel>
                        <TextBlock Text="🔍" FontFamily="Segoe UI Emoji" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   DockPanel.Dock="Left"/>
                        <Button x:Name="CloseSearchButton"
                                DockPanel.Dock="Right"
                                Command="{Binding ClearSearchCommand}"
                                ToolTip="Cerrar búsqueda (Esc)"
                                Margin="8,0,0,0" Padding="6,2"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource OnSurfaceVariantBrush}"
                                FontSize="13" VerticalAlignment="Center" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="✕" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="13"/>
                        </Button>
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource OnSurfaceBrush}"
                                 CaretBrush="{StaticResource OnSurfaceBrush}"
                                 VerticalContentAlignment="Center"
                                 Padding="0" FontFamily="Consolas" FontSize="13"
                                 KeyDown="SearchBox_KeyDown"/>
                    </DockPanel>
                </Border>

                <!-- Panel con lista de corridas (izquierda) + DataGrid (derecha) -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Auto: se colapsa a 0 cuando el panel izquierdo es Collapsed -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Panel izquierdo: lista de corridas (solo en modo Por Corrida) -->
                    <Border Grid.Column="0"
                            Width="220" Margin="0,0,8,0"
                            Visibility="{Binding LeftPanelVisibility}"
                            Background="{StaticResource SurfaceContainerHighBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="CORRIDAS"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       Margin="12,10,12,6" Opacity="0.7"/>

                            <ListBox x:Name="CorridasListBox"
                                     Grid.Row="1"
                                     ItemsSource="{Binding Corridas}"
                                     SelectedItem="{Binding SelectedCorrida, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Padding="4,0,4,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <!-- Separador "— Ayer —" (solo visible cuando IsSeparator=True) -->
                                            <TextBlock x:Name="SepText"
                                                       Text="— Ayer —"
                                                       Visibility="Collapsed"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11" FontStyle="Italic"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                       Opacity="0.6"
                                                       Margin="0,4"/>

                                            <!-- Histórico (drill-down desde MetricasView) -->
                                            <TextBlock x:Name="HistText"
                                                       Text="{Binding EtiquetaHistorico}"
                                                       Visibility="Collapsed"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryLightBrush}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Margin="4"/>

                                            <!-- Contenido normal de corrida -->
                                            <Grid x:Name="NormalGrid">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                <Setter Property="Opacity" Value="0.4"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Hora -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Hora}"
                                                           Foreground="White"
                                                           FontFamily="Consolas"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>

                                                <!-- Badge FULL / DELTA -->
                                                <Border Grid.Column="1" CornerRadius="4" Padding="5,2" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#555"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Tipo}" Value="FULL">
                                                                    <Setter Property="Background" Value="#0078D4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Tipo}"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Cantidad IDs -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CountText}"
                                                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                <Setter TargetName="SepText"    Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="NormalGrid" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsHistorico}" Value="True">
                                                <Setter TargetName="HistText"   Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="NormalGrid" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#303030"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                                        </MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <!-- Separador: no seleccionable, sin hover highlight -->
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                <Setter Property="IsEnabled"       Value="False"/>
                                                <Setter Property="Focusable"       Value="False"/>
                                                <Setter Property="Padding"         Value="0"/>
                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                            </DataTrigger>
                                            <!-- Corridas de ayer: opacidad reducida -->
                                            <DataTrigger Binding="{Binding IsDeAyer}" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- DataGrid modo Por Corrida -->
                    <DataGrid x:Name="DataGridCorrida"
                              Grid.Column="1"
                              ItemsSource="{Binding RegistrosCorrida}"
                              Visibility="{Binding DataGridCorridaVisibility}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              ClipboardCopyMode="IncludeHeader"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              Background="Transparent"
                              BorderThickness="0"
                              ColumnWidth="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A0078D4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"             Binding="{Binding Id}"             Width="Auto" MinWidth="160" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="NroComprobante" Binding="{Binding NroComprobante}" Width="Auto" MinWidth="140" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Planta"         Binding="{Binding Planta}"          Width="80" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="TipoComp"       Binding="{Binding TipoComprobante}" Width="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="CTG"            Binding="{Binding Ctg}"            Width="Auto" MinWidth="120" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Primera vez"    Binding="{Binding PrimeraVezVisto}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Última vez"     Binding="{Binding UltimaVezVisto}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="FecUpd"         Binding="{Binding FecUpd, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTemplateColumn Header="Anulado" Width="Auto" MinWidth="70" SortMemberPath="Anulado">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Setter Property="Foreground" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Anulado}" Value="True">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Cambios" Binding="{Binding Cambios}" Width="*" MinWidth="70" ElementStyle="{StaticResource DataCellStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- DataGrid modo Por ID único (agrega columna Corridas) -->
                    <DataGrid x:Name="DataGridUnico"
                              Grid.Column="1"
                              ItemsSource="{Binding RegistrosUnicos}"
                              SelectedItem="{Binding SelectedRegistroUnico, Mode=TwoWay}"
                              Visibility="{Binding DataGridUnicoVisibility}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              ClipboardCopyMode="IncludeHeader"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              Background="Transparent"
                              BorderThickness="0"
                              ColumnWidth="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A0078D4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Corridas"       Binding="{Binding CantidadCorridas}" Width="Auto" MinWidth="70" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="ID"             Binding="{Binding Id}"             Width="Auto" MinWidth="160" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="NroComprobante" Binding="{Binding NroComprobante}" Width="Auto" MinWidth="140" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Planta"         Binding="{Binding Planta}"          Width="80" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="TipoComp"       Binding="{Binding TipoComprobante}" Width="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="CTG"            Binding="{Binding Ctg}"            Width="Auto" MinWidth="120" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Primera vez"    Binding="{Binding PrimeraVezVisto}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="Última vez"     Binding="{Binding UltimaVezVisto}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTextColumn Header="FecUpd"         Binding="{Binding FecUpd, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="Auto" MinWidth="90" ElementStyle="{StaticResource DataCellStyle}"/>
                            <DataGridTemplateColumn Header="Anulado" Width="Auto" MinWidth="70" SortMemberPath="Anulado">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Setter Property="Foreground" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Anulado}" Value="True">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Cambios" Binding="{Binding Cambios}" Width="*" MinWidth="70" ElementStyle="{StaticResource DataCellStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- LineInfo -->
                <TextBlock Grid.Row="2"
                           Text="{Binding LineInfo}"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           FontSize="11"
                           Margin="4,6,0,0"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
