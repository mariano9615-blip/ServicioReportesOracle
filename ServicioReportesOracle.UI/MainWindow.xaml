<Window x:Class="ServicioReportesOracle.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ServicioReportesOracle.UI.ViewModels"
        xmlns:v="clr-namespace:ServicioReportesOracle.UI.Views"
        mc:Ignorable="d"
        Title="Servicio Oracle - Consola de Gestión"
        MinWidth="1000"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Icon="Assets/app.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlertasViewModel}">
            <v:AlertasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GeneralConfigViewModel}">
            <v:GeneralConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TasksViewModel}">
            <v:TasksView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SqlEditorViewModel}">
            <v:SqlEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <v:LogsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MlogisHistorialViewModel}">
            <v:MlogisHistorialView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MetricasViewModel}">
            <v:MetricasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ServiceControlViewModel}">
            <v:ServiceControlView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChangePasswordViewModel}">
            <v:ChangePasswordView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UiSettingsViewModel}">
            <v:UiSettingsView/>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HamburgerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de nav inferior (Button, no RadioButton) — igual visual que SidebarButtonStyle -->
        <Style x:Key="NavBottomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8,15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="5,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#303030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ErrorBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="Assets/app.ico" Width="16" Height="16" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Servicio Oracle — Consola de Gestión"
                               Foreground="{StaticResource OnSurfaceBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: window control buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimizar">
                        <TextBlock Text="&#x2013;" FontSize="16" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaxRestoreButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximizar">
                        <TextBlock x:Name="MaxRestoreIcon" Text="&#x25A1;" FontSize="13" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="TitleBarCloseButton_Click"
                            ToolTip="Cerrar">
                        <TextBlock Text="&#x2715;" FontSize="13" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="{StaticResource SurfaceBrush}" Margin="10" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header unificado (☰ + título + subtítulo) -->
                    <Grid Grid.Row="0" Margin="0,8,0,0">
                        <StackPanel VerticalAlignment="Center" Margin="20,0,52,6">
                            <TextBlock x:Name="SidebarTitle"
                                       Text="Servicio Oracle" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="SidebarSubtitle"
                                       Text="Consola de Gestión" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                        </StackPanel>
                        <Button x:Name="HamburgerBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,0,8,0"
                                Style="{StaticResource HamburgerButtonStyle}"
                                Click="ToggleSidebar_Click"
                                ToolTip="Contraer/expandir menú">
                            <TextBlock Text="☰" FontSize="16"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Row 1: Contenido de navegación -->
                    <StackPanel x:Name="NavContentPanel" Grid.Row="1" Margin="0">
                        <Border Height="1" Background="{StaticResource OutlineBrush}"
                                Opacity="0.3" Margin="12,4,12,8"/>

                        <RadioButton x:Name="NavBtn0" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" IsChecked="True" Command="{Binding NavDashboardCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="🏠" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText0" Text="Dashboard" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn8" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavAlertasCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="🔔" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <!-- Badge -->
                                    <Border Background="#F44336" Width="18" Height="18" CornerRadius="9"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-8,-10,0"
                                            Visibility="{Binding SidebarAlertVisible, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding SidebarAlertText}" Foreground="White" FontSize="10" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SidebarAlertVisible}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="NavText8" Text="Alertas" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn1" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavGeneralCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="⚙️" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText1" Text="Configuración General" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn2" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavTasksCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="📋" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText2" Text="Tareas SQL (JSON)" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn3" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavEditorCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="💻" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText3" Text="Editor SQL de Pruebas" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn4" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavLogsCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="📜" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText4" Text="Logs del Servicio" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn5" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavMlogisHistorialCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="📡" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText5" Text="Registros SOAP" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn9" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavMetricasCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="📈" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText9" Text="Métricas" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn6" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavServiceCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="🔧" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText6" Text="Control del Servicio" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtn7" Style="{StaticResource SidebarButtonStyle}" Padding="15,8" Command="{Binding NavChangePasswordCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="🔑" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavText7" Text="Cambiar Contraseña" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Row 2: Botón Analítica + UI Settings + Versión -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,0">
                        <Border Height="1" Background="{StaticResource OutlineBrush}"
                                Opacity="0.3" Margin="12,4,12,4"/>
                        <Button x:Name="NavBtnAnalitica"
                                Style="{StaticResource NavBottomButtonStyle}"
                                Click="AnaliticaButton_Click"
                                ToolTip="Abrir panel de analítica">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="📊" FontFamily="Segoe UI Emoji" FontSize="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavTextAnalitica" Text="Analítica"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavBtnSettings"
                                Style="{StaticResource NavBottomButtonStyle}"
                                Command="{Binding NavUiSettingsCommand}"
                                ToolTip="Configuración de Interfaz">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0" VerticalAlignment="Center" MinWidth="14">
                                    <TextBlock Text="⚙️" FontFamily="Segoe UI Emoji" FontSize="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavTextSettings" Text="Config. de Interfaz"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="VersionText"
                                   Text="v5.1"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,10"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   Opacity="0.5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding SelectedViewModel}" Margin="0,10,10,10"/>

            <!-- Notification Overlay -->
            <Border Grid.ColumnSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0"
                    Padding="20,10" CornerRadius="20" Panel.ZIndex="1000"
                    Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVis}}"
                    MaxWidth="400">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NotificationType}" Value="Error">
                                <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NotificationType}" Value="Success">
                                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔔" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                    <TextBlock Grid.Column="1" Text="{Binding NotificationMessage}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
