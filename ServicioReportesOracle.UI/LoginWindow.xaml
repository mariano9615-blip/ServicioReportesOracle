<Window x:Class="ServicioReportesOracle.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="480" Width="380"
        Icon="Assets/app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Foreground="White"
                                          Background="Transparent"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1084D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#006CBF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3DFF4B4B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer shadow container -->
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="16"
            MouseDown="Window_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <!-- Close button -->
            <Button Style="{StaticResource CloseButtonStyle}" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Margin="0,12,12,0"
                    Click="CloseButton_Click" FontSize="14">✕</Button>

            <StackPanel VerticalAlignment="Center" Margin="40,30,40,30">

                <!-- Logo / Icon area -->
                <Border Background="#1A0078D4" CornerRadius="20" Width="80" Height="80"
                        HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="SRO" FontSize="22" FontWeight="Black"
                                   Foreground="{StaticResource PrimaryLightBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="⚙" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Title -->
                <TextBlock Text="ServicioReportes" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Oracle Manager" FontSize="14"
                           Foreground="{StaticResource PrimaryLightBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" FontWeight="SemiBold"/>

                <!-- Divider -->
                <Border Height="1" Background="#2a2a2a" Margin="0,28,0,28"/>

                <!-- Password label -->
                <TextBlock Text="Contraseña de acceso" FontSize="12"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,6"/>

                <!-- PasswordBox with placeholder simulation -->
                <Grid>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"
                                 Height="44" PasswordChanged="PasswordBox_PasswordChanged"
                                 KeyDown="PasswordBox_KeyDown">
                        <!-- Overrides el color de sistema que usa PasswordBoxPresenter para dibujar los bullets -->
                        <PasswordBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                        </PasswordBox.Resources>
                    </PasswordBox>
                    <TextBlock x:Name="Placeholder" Text="Contraseña" VerticalAlignment="Center"
                               Foreground="#555" FontSize="14" Margin="14,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Error message -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Visibility="Collapsed"/>

                <!-- Login button -->
                <Button x:Name="LoginButton" Content="Ingresar"
                        Style="{StaticResource LoginButtonStyle}"
                        Height="48" Margin="0,20,0,0"
                        Click="LoginButton_Click"/>

                <!-- Blocked panel (visible after 3 failed attempts) -->
                <Border x:Name="BlockedPanel" Visibility="Collapsed"
                        Background="#1AFFC107" BorderBrush="{StaticResource WarningBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,16,0,0">
                    <TextBlock Text="Inicio de sesión bloqueado. Cerrá y volvé a abrir la aplicación para reintentar."
                               Foreground="{StaticResource WarningBrush}" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

            </StackPanel>
        </Grid>
    </Border>
</Window>
